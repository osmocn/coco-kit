{
  "name": "coco-kit",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @coco-kit/api dev",
    "dev:docs": "pnpm --filter @coco-kit/docs dev",
    "dev:web": "pnpm --filter @coco-kit/web dev",
    "dev:kill-ports": "npx kill-port 3000 && npx kill-port 3030 && npx kill-port 3060",
    "build": "turbo build",
    "lint": "biome check .",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @coco-kit/db db:generate",
    "db:migrate": "pnpm --filter @coco-kit/db db:migrate",
    "db:studio": "pnpm --filter @coco-kit/db db:studio",
    "check": "pnpm lint && pnpm typecheck",
    "format": "biome format --write .",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5"
  }
}
