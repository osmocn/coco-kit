{
  "name": "@coco-kit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "tsx --env-file=.env dist/index.js",
    "lint": "biome check .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@coco-kit/auth": "workspace:*",
    "@coco-kit/email": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
