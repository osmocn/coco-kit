{
  "name": "coco-kit",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:docs": "pnpm --filter @coco-kit/docs dev",
    "dev:web": "pnpm --filter @coco-kit/web dev",
    "build": "turbo build",
    "lint": "biome check .",
    "typecheck": "turbo typecheck",
    "check": "pnpm lint && pnpm typecheck",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5"
  }
}
